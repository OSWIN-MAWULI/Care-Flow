# HMS Environment Variables Example

# Node Environment
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173

# Database Connection (Neon PostgreSQL or Docker Local)
# For local Docker: postgresql://hms_admin:hms_password_2026@localhost:5432/hms_db?schema=public
DATABASE_URL="postgresql://username:password@hostname:5432/dbname?sslmode=require"

# Redis Cache / Real-time Queue (Upstash Redis or Docker Local)
# For local Docker: redis://localhost:6379
REDIS_URL="redis://localhost:6379"

# Authentication Secrets
JWT_SECRET="your-jwt-access-token-secret-change-me"
JWT_REFRESH_SECRET="your-jwt-refresh-token-secret-change-me"

# SMS Provider - Africa's Talking API
AFRICAS_TALKING_USERNAME="sandbox"
AFRICAS_TALKING_API_KEY="your-sandbox-api-key"
AFRICAS_TALKING_SENDER_ID="HMS_ALERTS" # Note: Sandbox might ignore this and use standard shortcode

# Cloudinary File Storage (Optional, dev fallbacks to local storage if empty)
CLOUDINARY_URL="cloudinary://api_key:api_secret@cloud_name"

# SMS Mode (set to 'mock' or 'sandbox' or 'production')
SMS_PROVIDER_MODE="mock"
